---
layout: layouts/base.njk
---
<main class="article">
  {% if eyebrow %}<p class="eyebrow">{{ eyebrow }}</p>{% endif %}
  <h1>{{ title }}</h1>
  <div class="meta">
    <span class="avatar">SM</span>
    <span>{{ site.author }}</span>
    <span>&middot;</span>
    <span>{{ page.date | readableDate }}</span>
    {% if readTime %}<span>&middot;</span><span>{{ readTime }} read</span>{% endif %}
  </div>
  <hr class="rule" />

  {% if cover %}
  <img class="post-cover" src="{{ cover }}" alt="" />
  {% endif %}

  {% if youtubeId and videoPosition != 'bottom' %}
  <div class="video">
    <iframe src="https://www.youtube.com/embed/{{ youtubeId }}" title="{{ title }}" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
  </div>
  {% endif %}

  <article>
    {{ content | safe }}
  </article>

  {% if youtubeId and videoPosition == 'bottom' %}
  <div class="video">
    <iframe src="https://www.youtube.com/embed/{{ youtubeId }}" title="{{ title }}" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
  </div>
  {% endif %}

  <div class="signup" id="signup">
    <h3>Want each tutorial in your inbox?</h3>
    <p>One short email when a new build-along goes live. No spam, no jargon.</p>
    <form class="form" action="https://buttondown.com/api/emails/embed-subscribe/WeCanBuild" method="post">
      <input type="email" name="email" placeholder="you@email.com" aria-label="Email address" required />
      <button class="btn" type="submit">Subscribe</button>
    </form>
    <p class="bd-credit"><a href="https://buttondown.com/refer/WeCanBuild" target="_blank" rel="noopener">Powered by Buttondown</a></p>
  </div>
</main>
