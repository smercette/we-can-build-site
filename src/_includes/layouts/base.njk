<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{% if title %}{{ title }} &mdash; {{ site.title }}{% else %}{{ site.title }} &mdash; {{ site.author }}{% endif %}</title>
  {% if description %}<meta name="description" content="{{ description }}" />{% endif %}

  {% set ogTitle = title or site.title %}
  {% set ogDescription = description or site.tagline %}
  {% set ogImage = cover or "/assets/images/we-can-build-icon.png" %}
  <meta property="og:type" content="{% if cover %}article{% else %}website{% endif %}" />
  <meta property="og:title" content="{{ ogTitle }}" />
  <meta property="og:description" content="{{ ogDescription }}" />
  <meta property="og:image" content="{{ site.url }}{{ ogImage }}" />
  <meta property="og:url" content="{{ site.url }}{{ page.url }}" />
  <meta property="og:site_name" content="{{ site.title }}" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{ ogTitle }}" />
  <meta name="twitter:description" content="{{ ogDescription }}" />
  <meta name="twitter:image" content="{{ site.url }}{{ ogImage }}" />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/style.css">
</head>
<body>
  {% include "partials/header.njk" %}
  {{ content | safe }}
  {% include "partials/footer.njk" %}
</body>
</html>
